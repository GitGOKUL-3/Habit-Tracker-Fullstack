# ─────────────────────────────────────────────────────────────────────────────
# TiDB Cloud connection (get values from TiDB Cloud console → Connect)
# ─────────────────────────────────────────────────────────────────────────────
DB_HOST=<your-cluster>.tidbcloud.com
DB_USER=<your-username>.root
DB_PASSWORD=<your-password>
DB_NAME=habit_tracker
DB_PORT=4000
DB_SSL=true

JWT_SECRET=your_strong_jwt_secret_here

# ─────────────────────────────────────────────────────────────────────────────
# Local MySQL (for offline development)
# ─────────────────────────────────────────────────────────────────────────────
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=your_local_mysql_password
# DB_NAME=habit_tracker
# DB_PORT=3306
# DB_SSL=false
